<% layout("/layouts/boilerplate") %>

    <div class="row">
        <div class="col-8 offset-3  mt-3">
            <h3>
                <%= Listings.title %>
            </h3><br />
        </div>

        <div class="card col-6 offset-3 listing-card">
            <img src="<%= Listings.image.url || Listings.image %>" class="card-img-top show-img" alt="List_image">
            <div class="card-body">
                <p class="card-text"><i>Owner: <%= Listings.owner ? Listings.owner.username : "Unknown" %></i></p>
                <p class="card-text">
                    <%= Listings.description %>
                </p>
                <p class="card-text">&#8377; <%= Listings.price.toLocaleString("en-IN") %>
                </p>
                <p class="card-text">
                    <%= Listings.location %>
                </p>
                <p class="card-text">
                    <%= Listings.country %>
                </p>
            </div>
        </div>
        <br />
        <div class="btns mb-5">
            <a href="/listings/<%= Listings._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>
            <br />
            <form action="/listings/<%= Listings._id %>?_method=DELETE" method="post">
                <button class="btn btn-dark offset-5">Delete</button>
            </form>
        </div>
        <hr />
        <div class="col-8 offset-3 mb-4 mt-3">
            <% if(currUser) { %>
                <h3>Reviews</h3>
                <form action="/listings/<%= Listings._id %>/reviews" method="post" novalidate class="needs-validation">
                    <div>
                        <label for="rating" class="form-label">Rating</label>
                        <fieldset class="starability-grow">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1"
                                checked aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>

                    <div>
                        <label for="comment" class="form-label">Comments</label>
                        <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                            required></textarea>
                        <div class="invalid-feedback">Please add some Review</div>
                    </div>
                    <button type="submit" class="btn btn-outline-dark mt-3">Submit</button>
                </form>
                <hr />
                <% }%>

                    <% if(Listings.reviews.length> 0) { %>
                        <div class="row">
                            <p><strong>All Reviews</strong></p>
                            <% for(let review of Listings.reviews){ %>
                                <div class="card col-5 ms-2 mb-3">
                                    <div class="card-body">
                                        <h5 class="card-title">@<%= review.author.username %>
                                        </h5>
                                        <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                                        <p class="card-text">
                                            <strong>Rating:</strong>
                                            <%= review.rating %> stars <br />
                                                <strong>Comment:</strong>
                                                <%= review.comment %>
                                                    <p>date: <%= review.CreatedAt ?
                                                            review.CreatedAt.toLocaleDateString("en-IN") : "N/A" %>
                                                    </p>
                                        </p>
                                    </div>
                                    <form
                                        action="/listings/<%= Listings._id %>/reviews/<%= review._id %>?_method=DELETE"
                                        method="post">
                                        <button class="btn btn-dark mb-2">Delete</button>
                                    </form>
                                </div>

                                <% } %>
                        </div>
                        <% } else { %>
                            <p>No reviews yet. Be the first to review!</p>
                            <%} %>
        </div>
        <div class="col-7 offset-3  mt-3 mb-5">
            <h3>Where you will be staying</h3>
             <% if (Listings.geometry && Listings.geometry.coordinates) { %>
            <div id="map" data-coordinates='<%- JSON.stringify(Listings.geometry.coordinates) %>'
                data-location="<%= Listings.location %>">
            </div>
            <% } else { %>
 <p>Location map unavailable</p>
<% } %>

           
   

  
        </div>
    </div>

